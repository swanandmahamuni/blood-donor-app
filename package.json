{
  "main": "public/electron.js",
  "homepage": ".",
  "name": "aniruddhas-acaademy-of-disaster-management-mega-blood-donation-camp",
  "version": "0.1.0",
  "private": true,
  "description": "Aniruddhas Academy of Disaster Management Mega Blood Donation Camp",
  "author": "Swanandsinh Ashok Mahamuni",
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "concurrently": "^9.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-scripts": "5.0.1",
    "wait-on": "^9.0.5",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron .",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "dist": "react-scripts build && electron-builder"
  },
  "build": {
    "appId": "com.aadm.blooddonor",
    "productName": "Aniruddha's Academy of Disaster Management - Mega Blood Donation Camp",
    "icon": "public/icon.ico",
    "files": [
      "build/**/*",
      "public/electron.js"
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": "nsis"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
